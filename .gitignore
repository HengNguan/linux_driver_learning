# ============================================
# Linux Kernel Module Development - .gitignore
# ============================================

# --- Kernel module build artifacts ---
*.ko
*.o
*.mod
*.mod.c
*.mod.o

# --- Kernel build system generated files ---
Module.symvers
modules.order

# --- Hidden dependency files generated by kbuild ---
.*.cmd

# --- Compiled user-space test binaries ---
cdev_test
testapp

# --- Editor / OS files ---
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
